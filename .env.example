# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/upstox_bot

# Upstox API Configuration (Get from https://api-v2.upstox.com/)
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:5000/api/system/auth-callback

# Server Configuration
PORT=5000
NODE_ENV=development

# STRICTLY REQUIRED for remote API and WebSocket access.
# If you are exposing Mimir over a Cloudflare Tunnel or public IP, you MUST set this token.
UPSTOXBOT_ADMIN_TOKEN=

# Optional: comma-separated allowed origins for backend and AI service CORS.
AI_CORS_ORIGINS=http://localhost:5000

# Optional: remote API rate limit for non-local clients.
UPSTOXBOT_RATE_LIMIT_WINDOW_MS=60000
UPSTOXBOT_RATE_LIMIT_MAX=120

# Optional but recommended: stable encryption key for persisted API secrets/tokens.
# Keep it unchanged once secrets have been saved.
UPSTOXBOT_SECRET_KEY=replace_with_a_long_random_secret
