{
  "name": "mimir-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start:api": "node --enable-source-maps ./dist/api_server.mjs",
    "start:engine": "node --enable-source-maps ./dist/trading_engine.mjs",
    "dev": "node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "setup:db": "npm run setup:tables",
    "setup:tables": "node ./dist/migrate.mjs",
    "db:push": "drizzle-kit push --config ./db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./db/drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:preflight": "tsx ./scripts/preflight.ts",
    "test:cache": "vitest run tests/cache",
    "test:perf": "vitest run tests/perf",
    "test:all": "npm run test:preflight && vitest run",
    "ranker:extract": "tsx ./scripts/extract_training_data.ts",
    "ranker:train": "npm run ranker:extract && python ./ai_service/train_ranker.py",
    "ranker:train:only": "python ./ai_service/train_ranker.py"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "ioredis": "^5.11.1",
    "msgpackr": "^2.0.4",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "playwright": "^1.61.1",
    "protobufjs": "^7.4.0",
    "rss-parser": "^3.13.0",
    "upstox-js-sdk": "^2.29.0",
    "ws": "^8.20.1",
    "yahoo-finance2": "^3.15.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8.2.7",
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "eslint": "^10.7.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.8"
  }
}
