{
  "name": "mimir-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start:api": "node --enable-source-maps ./dist/api_server.mjs",
    "start:engine": "node --enable-source-maps ./dist/trading_engine.mjs",
    "dev": "node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "setup:db": "node ./setup-db.mjs",
    "setup:tables": "node ./setup-tables.mjs",
    "db:push": "drizzle-kit push --config ./db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./db/drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "ioredis": "^5.11.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "protobufjs": "^7.4.0",
    "ws": "^8.20.1",
    "yahoo-finance2": "^3.15.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "eslint": "^10.5.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.8"
  }
}
